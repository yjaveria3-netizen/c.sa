# Factorial applications
print("\n--- Factorial Applications ---");

# Calculate number of ways to arrange n distinct items
function arrangements(n) {
    return factorial_iterative(n);
}

# Calculate number of ways to select k items from n (order matters)
function permutations_app(n, k) {
    return permutations(n, k);
}

# Calculate number of ways to select k items from n (order doesn't matter)
function combinations_app(n, k) {
    return combinations(n, k);
}

# Calculate number of ways to arrange n items in a circle
function circular_arrangements(n) {
    if (n <= 2) {
        return 1;
    }
    return factorial_iterative(n - 1);
}

print("Arrangement problems:");
print("Ways to arrange 5 people in a line:", arrangements(5));
print("Ways to arrange 5 people in a circle:", circular_arrangements(5));
print("Ways to choose 3 people from 5:", combinations_app(5, 3));
print("Ways to arrange 3 people from 5 in order:", permutations_app(5, 3));

# Factorial overflow simulation
print("\n--- Factorial Overflow Simulation ---");

function find_overflow_limit() {
    # Simulate 32-bit integer limit
    let int32_limit = 2147483647;
    let n = 1;
    while (factorial_iterative(n) <= int32_limit) {
        n++;
    }
    print("32-bit integer overflow at", n, "! =", factorial_iterative(n));
    
    # Simulate 64-bit integer limit
    let int64_limit = 9223372036854775807;
    n = 1;
    while (factorial_iterative(n) <= int64_limit) {
        n++;
    }
    print("64-bit integer overflow at", n, "! =", factorial_iterative(n));
}

find_overflow_limit();

print("\nFactorial calculation examples completed!");
