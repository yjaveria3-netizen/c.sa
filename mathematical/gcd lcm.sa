# gcd_lcm.sa - GCD and LCM Calculation Examples
# C-style GCD and LCM implementation in Quantum Language

print("=== GCD and LCM Calculation Examples ===");

# Euclidean algorithm for GCD (iterative)
function gcd_iterative(a, b) {
    a = abs(a);
    b = abs(b);
    
    while (b != 0) {
        let temp = b;
        b = a % b;
        a = temp;
    }
    
    return a;
}

# Euclidean algorithm for GCD (recursive)
function gcd_recursive(a, b) {
    a = abs(a);
    b = abs(b);
    
    if (b == 0) {
        return a;
    }
    
    return gcd_recursive(b, a % b);
}

# Extended Euclidean algorithm
function extended_gcd(a, b) {
    if (b == 0) {
        return {"gcd": a, "x": 1, "y": 0};
    }
    
    let result = extended_gcd(b, a % b);
    let gcd = result.gcd;
    let x1 = result.x;
    let y1 = result.y;
    
    let x = y1;
    let y = x1 - (a / b) * y1;
    
    return {"gcd": gcd, "x": x, "y": y};
}

# LCM using GCD
function lcm(a, b) {
    if (a == 0 || b == 0) {
        return 0;
    }
    
    return abs(a * b) / gcd_iterative(a, b);
}

# GCD of multiple numbers
function gcd_multiple(numbers) {
    if (len(numbers) == 0) {
        return 0;
    }
    
    let result = numbers[0];
    for (let i = 1; i < len(numbers); i++) {
        result = gcd_iterative(result, numbers[i]);
    }
    
    return result;
}

# LCM of multiple numbers
function lcm_multiple(numbers) {
    if (len(numbers) == 0) {
        return 0;
    }
    
    let result = numbers[0];
    for (let i = 1; i < len(numbers); i++) {
        result = lcm(result, numbers[i]);
    }
    
    return result;
}

# Test basic GCD and LCM functions
print("\n--- Testing Basic GCD and LCM Functions ---");

let test_pairs = [
    [48, 18],
    [12, 8],
    [17, 23],
    [100, 25],
    [0, 5],
    [-12, 18]
];

for (let pair in test_pairs) {
    let a = pair[0];
    let b = pair[1];
    
    print("Numbers:", a, "and", b);
    print("GCD (iterative):", gcd_iterative(a, b));
    print("GCD (recursive):", gcd_recursive(a, b));
    print("LCM:", lcm(a, b));
    print("");
}

# Test extended Euclidean algorithm
print("--- Testing Extended Euclidean Algorithm ---");

let extended_test_pairs = [
    [48, 18],
    [35, 15],
    [99, 78],
    [240, 46]
];

for (let pair in extended_test_pairs) {
    let a = pair[0];
    let b = pair[1];
    
    let result = extended_gcd(a, b);
    print("Extended GCD for", a, "and", b);
    print("GCD:", result.gcd);
    print("Coefficients x, y:", result.x, result.y);
    print("Verification:", a, "*", result.x, "+", b, "*", result.y, "=", 
          a * result.x + b * result.y);
    print("");
}

