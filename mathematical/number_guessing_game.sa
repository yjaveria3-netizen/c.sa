#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    srand(time(NULL));
    int number = rand() % 100 + 1;
    int guess;
    
    printf("Guess the number between 1 and 100: ");
    scanf("%d", &guess);
    
    if (guess == number) {
        printf("Congratulations! You guessed it right!\n");
    } else {
        printf("Wrong! The number was %d\n", number);
    }
    
    return 0;
}
