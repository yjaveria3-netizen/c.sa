print("\n--- AI vs AI Tournament ---");
let tournament_players = ["AI_Alpha", "AI_Beta", "AI_Gamma"];
let tournament = Tournament(tournament_players);
tournament.play_round_robin();

# Interactive game
print("\n--- Interactive Game ---");
let controller = GameController();
controller.start_game();
controller.play_again();

# Statistics tracking
print("\n=== Game Statistics ===");

class GameStats {
    constructor() {
        this.games_played = 0;
        this.x_wins = 0;
        self.o_wins = 0;
        this.draws = 0;
        this.total_moves = 0;
        this.shortest_game = 999;
        this.longest_game = 0;
    }
    
    record_game(winner, moves) {
        this.games_played++;
        this.total_moves += moves;
        
        if (winner == 'X') {
            this.x_wins++;
        } else if (winner == 'O') {
            this.o_wins++;
        } else {
            this.draws++;
        }
        
        if (moves < this.shortest_game) {
            this.shortest_game = moves;
        }
        
        if (moves > this.longest_game) {
            this.longest_game = moves;
        }
    }
    
    display_stats() {
        print("Game Statistics:");
        print("================");
        print("Games played:", this.games_played);
        print("X wins:", this.x_wins, "(", (this.x_wins / this.games_played * 100).toFixed(1), "%)");
        print("O wins:", this.o_wins, "(", (this.o_wins / this.games_played * 100).toFixed(1), "%)");
        print("Draws:", this.draws, "(", (this.draws / this.games_played * 100).toFixed(1), "%)");
        print("Average moves per game:", (this.total_moves / this.games_played).toFixed(1));
        print("Shortest game:", this.shortest_game, "moves");
        print("Longest game:", this.longest_game, "moves");
    }
}

# Simulate multiple games and track statistics
let stats = GameStats();

print("Simulating 100 AI vs AI games...");
for (let i = 0; i < 100; i++) {
    let sim_game = TicTacToe();
    let sim_ai1 = AIPlayer('X');
    let sim_ai2 = AIPlayer('O');
    
    while (!sim_game.game_over) {
        if (sim_game.current_player == 'X') {
            let move = sim_ai1.get_best_move(sim_game);
            sim_game.make_move(move[0], move[1]);
        } else {
            let move = sim_ai2.get_best_move(sim_game);
            sim_game.make_move(move[0], move[1]);
        }
    }
    
    stats.record_game(sim_game.winner, sim_game.moves);
}

stats.display_stats();

print("\nTic Tac Toe game completed!");
