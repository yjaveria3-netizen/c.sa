# string_validation.sa - String Validation Examples
# C-style string validation implementation in Quantum Language

print("=== String Validation Examples ===");

# Check if string is empty
function is_empty(str) {
    return len(str) == 0;
}

# Check if string contains only whitespace
function is_whitespace(str) {
    if (len(str) == 0) {
        return false;
    }
    
    for (let i = 0; i < len(str); i++) {
        let char = str[i];
        if (char != ' ' && char != '\t' && char != '\n' && char != '\r') {
            return false;
        }
    }
    
    return true;
}

# Check if string is numeric (digits only)
function is_numeric(str) {
    if (len(str) == 0) {
        return false;
    }
    
    for (let i = 0; i < len(str); i++) {
        let char = str[i];
        if (char < '0' || char > '9') {
            return false;
        }
    }
    
    return true;
}

# Check if string is alphabetic (letters only)
function is_alpha(str) {
    if (len(str) == 0) {
        return false;
    }
    
    for (let i = 0; i < len(str); i++) {
        let char = str[i];
        if (!((char >= 'a' && char <= 'z') || (char >= 'A' && char <= 'Z'))) {
            return false;
        }
    }
    
    return true;
}

# Check if string is alphanumeric (letters and digits)
function is_alphanumeric(str) {
    if (len(str) == 0) {
        return false;
    }
    
    for (let i = 0; i < len(str); i++) {
        let char = str[i];
        if (!((char >= 'a' && char <= 'z') || 
              (char >= 'A' && char <= 'Z') || 
              (char >= '0' && char <= '9'))) {
            return false;
        }
    }
    
    return true;
}

# Check if string is a valid email address (basic validation)
function is_email(str) {
    if (len(str) == 0) {
        return false;
    }
    
    # Basic email validation: local@domain
    let at_count = 0;
    let at_pos = -1;
    
    # Count @ symbols and find position
    for (let i = 0; i < len(str); i++) {
        if (str[i] == '@') {
            at_count++;
            at_pos = i;
        }
    }
    
    if (at_count != 1) {
        return false;
    }
    
    # Check local part (before @)
    let local_part = str.slice(0, at_pos);
    if (len(local_part) == 0) {
        return false;
    }
    
    # Check domain part (after @)
    let domain_part = str.slice(at_pos + 1);
    if (len(domain_part) == 0) {
        return false;
    }
    
    # Domain should contain at least one dot
    if (!domain_part.contains('.')) {
        return false;
    }
    
    # Basic character checks
    for (let i = 0; i < len(str); i++) {
        let char = str[i];
        if (char == ' ' || char == '\t' || char == '\n' || char == '\r') {
            return false;
        }
    }
    
    return true;
}

# Check if string is a valid phone number (basic US format)
function is_phone_number(str) {
    if (len(str) == 0) {
        return false;
    }
    
    # Remove common separators
    let cleaned = "";
    for (let i = 0; i < len(str); i++) {
        let char = str[i];
        if (char >= '0' && char <= '9') {
            cleaned += char;
        }
    }
    
    # Check if we have exactly 10 digits
    return len(cleaned) == 10;
}

# Check if string is a valid URL (basic validation)
function is_url(str) {
    if (len(str) == 0) {
        return false;
    }
    
    # Must contain http:// or https://
    if (!(str.slice(0, 7) == "http://" || str.slice(0, 8) == "https://")) {
        return false;
    }
    
    # Must contain at least one dot after protocol
    let protocol_end = str.index("://") + 3;
    let domain = str.slice(protocol_end);
    
    if (len(domain) == 0 || !domain.contains('.')) {
        return false;
    }
    
    return true;
}

# Check if string is a valid IPv4 address
function is_ipv4(str) {
    if (len(str) == 0) {
        return false;
    }
    
    # Split by dots
    let parts = str.split('.');
    
    if (len(parts) != 4) {
        return false;
    }
    
    for (let part in parts) {
        # Each part must be numeric
        if (!is_numeric(part)) {
            return false;
        }
        
        # Convert to integer and check range
        let num = parseInt(part);
        if (num < 0 || num > 255) {
            return false;
        }
        
        # No leading zeros (except for "0")
        if (len(part) > 1 && part[0] == '0') {
            return false;
        }
    }
    
    return true;
}

# Check if string matches a pattern (basic pattern matching)
function matches_pattern(str, pattern) {
    if (len(str) != len(pattern)) {
        return false;
    }
    
    for (let i = 0; i < len(str); i++) {
        let pattern_char = pattern[i];
        let str_char = str[i];
        
        if (pattern_char == '?') {
            # Wildcard - matches any character
            continue;
        } else if (pattern_char == '*') {
            # Not implemented in this basic version
            return false;
        } else if (pattern_char != str_char) {
            return false;
        }
    }
    
    return true;
}

