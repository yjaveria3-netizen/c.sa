}

# String validation class
print("\n--- String Validation Class ---");

class StringValidator {
    constructor() {
        this.validation_history = [];
    }
    
    # Validate with custom rules
    validate(str, rules) {
        let results = {};
        
        for (let rule_name in rules) {
            let rule = rules[rule_name];
            let result = false;
            
            if (rule == "required") {
                result = !is_empty(str);
            } else if (rule == "numeric") {
                result = is_numeric(str);
            } else if (rule == "alpha") {
                result = is_alpha(str);
            } else if (rule == "alphanumeric") {
                result = is_alphanumeric(str);
            } else if (rule == "email") {
                result = is_email(str);
            } else if (rule == "phone") {
                result = is_phone_number(str);
            } else if (rule == "url") {
                result = is_url(str);
            } else if (rule.slice(0, 11) == "min_length:") {
                let min_len = parseInt(rule.split(":")[1]);
                result = len(str) >= min_len;
            } else if (rule.slice(0, 11) == "max_length:") {
                let max_len = parseInt(rule.split(":")[1]);
                result = len(str) <= max_len;
            }
            
            results[rule_name] = result;
        }
        
        # Record validation
        this.validation_history.push({
            "input_text": str,
            "rules": rules,
            "results": results,
            "timestamp": time()
        });
        
        return results;
    }
    
    # Get validation history
    get_history() {
        return this.validation_history;
    }
    
    # Clear history
    clear_history() {
        this.validation_history = [];
        print("Validation history cleared");
    }
}

# Test validation class
let validator = StringValidator();

print("Testing StringValidator:");
let validation_rules = {
    "not_empty": "required",
    "is_email": "email",
    "min_length_5": "min_length:5"
};

let test_inputs = ["", "test", "test@example.com", "a@b.c"];

for (let test_input in test_inputs) {
    let results = validator.validate(test_input, validation_rules);
    print("Test Input:", test_input, "Results:", results);
}

# Form validation example
print("\n--- Form Validation Example ---");

function validate_registration_form(data) {
    let errors = [];
    
    # Validate name
    if (is_empty(data.name)) {
        errors.push("Name is required");
    } else if (!is_alpha(data.name.replace(" ", ""))) {
        errors.push("Name should contain only letters");
    } else if (len(data.name) < 2) {
        errors.push("Name should be at least 2 characters");
    }
    
    # Validate email
    if (is_empty(data.email)) {
        errors.push("Email is required");
    } else if (!is_email(data.email)) {
        errors.push("Invalid email format");
    }
    
    # Validate age
    if (is_empty(data.age)) {
        errors.push("Age is required");
    } else if (!is_numeric(data.age)) {
        errors.push("Age should be a number");
    } else {
        let age = parseInt(data.age);
        if (age < 18 || age > 120) {
            errors.push("Age should be between 18 and 120");
        }
    }
    
    # Validate phone
    if (!is_empty(data.phone) && !is_phone_number(data.phone)) {
        errors.push("Invalid phone number format");
    }
    
    return errors;
}

# Test form validation
let form_data = {
    "name": "John Doe",
    "email": "john@example.com",
    "age": "25",
    "phone": "(555) 123-4567"
};

let form_errors = validate_registration_form(form_data);

if (len(form_errors) == 0) {
    print("Form validation passed!");
} else {
    print("Form validation errors:");
    for (let error in form_errors) {
        print("  -", error);
    }
}

# Performance test
print("\n--- Performance Test ---");

function performance_test() {
    let test_string = "The quick brown fox jumps over the lazy dog";
    let iterations = 10000;
    
    # Test is_numeric
    let start_time = time();
    for (let i = 0; i < iterations; i++) {
        is_numeric(test_string);
    }
    let numeric_time = time() - start_time;
    
    # Test is_alpha
    start_time = time();
    for (let i = 0; i < iterations; i++) {
        is_alpha(test_string);
    }
    let alpha_time = time() - start_time;
    
    # Test is_alphanumeric
    start_time = time();
    for (let i = 0; i < iterations; i++) {
        is_alphanumeric(test_string);
    }
    let alphanumeric_time = time() - start_time;
    
    print("Performance test with", iterations, "iterations:");
    print("is_numeric:", numeric_time, "seconds");
    print("is_alpha:", alpha_time, "seconds");
    print("is_alphanumeric:", alphanumeric_time, "seconds");
}

performance_test();

}

print("\nString validation examples completed!");
