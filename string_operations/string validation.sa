# Advanced validation functions
print("\n--- Advanced Validation Functions ---");

# Check password strength
function check_password_strength(password) {
    if (len(password) == 0) {
        return {"strength": "none", "score": 0};
    }
    
    let score = 0;
    let feedback = [];
    
    # Length check
    if (len(password) >= 8) {
        score += 2;
    } else {
        feedback.push("Password should be at least 8 characters");
    }
    
    # Contains lowercase
    let has_lower = false;
    let has_upper = false;
    let has_digit = false;
    let has_special = false;
    
    for (let i = 0; i < len(password); i++) {
        let char = password[i];
        if (char >= 'a' && char <= 'z') {
            has_lower = true;
        } else if (char >= 'A' && char <= 'Z') {
            has_upper = true;
        } else if (char >= '0' && char <= '9') {
            has_digit = true;
        } else {
            has_special = true;
        }
    }
    
    if (has_lower) {
        score += 1;
    } else {
        feedback.push("Password should contain lowercase letters");
    }
    
    if (has_upper) {
        score += 1;
    } else {
        feedback.push("Password should contain uppercase letters");
    }
    
    if (has_digit) {
        score += 1;
    } else {
        feedback.push("Password should contain digits");
    }
    
    if (has_special) {
        score += 1;
    } else {
        feedback.push("Password should contain special characters");
    }
    
    # Determine strength
    let strength;
    if (score >= 5) {
        strength = "very strong";
    } else if (score >= 4) {
        strength = "strong";
    } else if (score >= 3) {
        strength = "moderate";
    } else if (score >= 2) {
        strength = "weak";
    } else {
        strength = "very weak";
    }
    
    return {
        "strength": strength,
        "score": score,
        "feedback": feedback
    };
}

# Test password strength
let password_tests = [
    "password",
    "Password",
    "Password123",
    "P@ssw0rd!",
    "123",
    "aB1!",
    "VeryStrongPassword123!"
];

print("Password\t\t\tStrength\tScore");
print("--------\t\t\t--------\t-----");

for (let password in password_tests) {
    let result = check_password_strength(password);
    print(password + "\t\t\t" + result.strength + "\t" + str(result.score));
}

# Credit card validation (Luhn algorithm)
function is_valid_credit_card(card_number) {
    # Remove spaces and dashes
    let cleaned = "";
    for (let i = 0; i < len(card_number); i++) {
        let char = card_number[i];
        if (char >= '0' && char <= '9') {
            cleaned += char;
        }
    }
    
    if (len(cleaned) < 13 || len(cleaned) > 19) {
        return false;
    }
    
    # Luhn algorithm
    let sum = 0;
    let double_digit = false;
    
    for (let i = len(cleaned) - 1; i >= 0; i--) {
        let digit = parseInt(cleaned[i]);
        
        if (double_digit) {
            digit *= 2;
            if (digit > 9) {
                digit = digit - 9;
            }
        }
        
        sum += digit;
        double_digit = !double_digit;
    }
    
    return sum % 10 == 0;
}

