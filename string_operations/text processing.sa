# Performance test
print("\n--- Performance Test ---");

function performance_test() {
    let large_text = "";
    for (let i = 0; i < 1000; i++) {
        large_text += "This is line " + str(i) + " of the test text. ";
    }
    
    let iterations = 100;
    
    # Test word frequency
    let start_time = time();
    for (let i = 0; i < iterations; i++) {
        get_word_frequency(large_text);
    }
    let word_freq_time = time() - start_time;
    
    # Test text statistics
    start_time = time();
    for (let i = 0; i < iterations; i++) {
        get_text_statistics(large_text);
    }
    let stats_time = time() - start_time;
    
    print("Performance test with", len(large_text), "characters,", iterations, "iterations:");
    print("Word frequency:", word_freq_time, "seconds");
    print("Text statistics:", stats_time, "seconds");
}

performance_test();

}

