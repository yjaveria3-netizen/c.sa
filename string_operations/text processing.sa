# Text processing class
print("\n--- Text Processing Class ---");

class TextProcessor {
    constructor() {
        this.original_text = "";
        this.processed_text = "";
        this.statistics = {};
        this.history = [];
    }
    
    # Load text
    load_text(text) {
        this.original_text = text;
        this.processed_text = text;
        this.statistics = get_text_statistics(text);
        this.record_operation("load", text);
    }
    
    # Apply transformation
    apply_transformation(transformation, ...args) {
        if (transformation == "clean") {
            this.processed_text = remove_extra_whitespace(this.processed_text);
        } else if (transformation == "lowercase") {
            this.processed_text = to_lowercase(this.processed_text);
        } else if (transformation == "uppercase") {
            this.processed_text = to_uppercase(this.processed_text);
        } else if (transformation == "capitalize") {
            this.processed_text = capitalize_words(this.processed_text);
        } else if (transformation == "remove_punctuation") {
            this.processed_text = remove_punctuation(this.processed_text);
        } else if (transformation == "reverse") {
            this.processed_text = reverse_text(this.processed_text);
        } else if (transformation == "replace") {
            this.processed_text = replace_all(this.processed_text, args[0], args[1]);
        }
        
        this.record_operation(transformation, args);
    }
    
    # Get word frequency
    get_word_frequency() {
        return get_word_frequency(this.processed_text);
    }
    
    # Get most common words
    get_most_common_words(limit = 10) {
        return get_most_common_words(this.processed_text, limit);
    }
    
    # Search text
    search(term, case_sensitive = true) {
        return {
            "count": count_occurrences(this.processed_text, term, case_sensitive),
            "positions": find_all_occurrences(this.processed_text, term, case_sensitive)
        };
    }
    
    # Record operation
    record_operation(operation, args) {
        this.history.push({
            "operation": operation,
            "args": args,
            "timestamp": time()
        });
    }
    
    # Reset to original
    reset() {
        this.processed_text = this.original_text;
        this.record_operation("reset", []);
    }
    
    # Get current text
    get_text() {
        return this.processed_text;
    }
    
    # Get statistics
    get_statistics() {
        return get_text_statistics(this.processed_text);
    }
    
    # Get history
    get_history() {
        return this.history;
    }
}

# Test text processor class
let processor = TextProcessor();
processor.load_text(sample_text);

print("Testing TextProcessor:");
print("Original length:", len(processor.get_text()));

processor.apply_transformation("lowercase");
