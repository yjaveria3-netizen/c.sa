processor.apply_transformation("remove_punctuation");
print("After removing punctuation:", processor.get_text());

processor.apply_transformation("clean");
print("After cleaning:", processor.get_text());

print("\nSearch results:");
let search_results = processor.search("lazy", false);
print("Found 'lazy' count:", search_results.count);
print("Positions:", search_results.positions);

print("\nMost common words:");
let common = processor.get_most_common_words(3);
for (let item in common) {
    print(item.word + ":", item.count);
}

# File processing
if (false) {
print("\n--- File Processing ---");

function process_file_content(filename) {
    let content = read_file(filename);
    if (content != null) {
        print("Processing file:", filename);
        
        let stats = get_text_statistics(content);
        print("File statistics:");
        print("  Characters:", stats.characters);
        print("  Words:", stats.words);
        print("  Lines:", stats.lines);
        
        let word_freq = get_word_frequency(content);
        let most_common = get_most_common_words(content, 5);
        
        print("Most common words:");
        for (let item in most_common) {
            print("  ", item.word + ":", item.count);
        }
        
        return content;
    }
    
    return null;
}

