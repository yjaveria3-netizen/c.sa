# text_processing.sa - Text Processing Examples
# C-style text processing implementation in Quantum Language

print("=== Text Processing Examples ===");

# Text statistics
function get_text_statistics(text) {
    if (len(text) == 0) {
        return {
            "characters": 0,
            "words": 0,
            "sentences": 0,
            "paragraphs": 0,
            "lines": 0
        };
    }
    
    let char_count = len(text);
    
    # Count words
    let words = text.split(/\s+/);
    let word_count = 0;
    for (let word in words) {
        if (word.trim() != "") {
            word_count++;
        }
    }
    
    # Count sentences (simple approach)
    let sentence_count = 0;
    let sentence_endings = [".", "!", "?"];
    for (let i = 0; i < len(text); i++) {
        if (sentence_endings.contains(text[i])) {
            sentence_count++;
        }
    }
    
    # Count paragraphs
    let paragraphs = text.split(/\n\s*\n/);
    let paragraph_count = 0;
    for (let para in paragraphs) {
        if (para.trim() != "") {
            paragraph_count++;
        }
    }
    
    # Count lines
    let lines = text.split("\n");
    let line_count = len(lines);
    
    return {
        "characters": char_count,
        "words": word_count,
        "sentences": sentence_count,
        "paragraphs": paragraph_count,
        "lines": line_count
    };
}

# Text cleaning functions
function remove_extra_whitespace(text) {
    # Replace multiple spaces with single space
    let result = text.replace(/\s+/g, " ");
    # Trim leading and trailing whitespace
    return result.trim();
}

function remove_punctuation(text) {
    let punctuation = ".,!?;:\"'()[]{}<>-";
    let result = "";
    
    for (let i = 0; i < len(text); i++) {
        let char = text[i];
        if (!punctuation.contains(char)) {
            result += char;
        }
    }
    
    return result;
}

function to_lowercase(text) {
    return text.lower();
}

function to_uppercase(text) {
    return text.upper();
}

function capitalize_words(text) {
    let words = text.split(" ");
    let result = [];
    
    for (let word in words) {
        if (len(word) > 0) {
            let capitalized = word[0].upper() + word.slice(1).lower();
            result.push(capitalized);
        } else {
            result.push(word);
        }
    }
    
    return result.join(" ");
}

# Text search functions
function find_all_occurrences(text, search_term, case_sensitive = true) {
    if (!case_sensitive) {
        text = text.lower();
        search_term = search_term.lower();
    }
    
    let occurrences = [];
    let start = 0;
    
    while (true) {
        let index = text.index(search_term);
        if (index == -1) {
            break;
        }
        
        occurrences.push(start + index);
        text = text.slice(index + 1);
        start += index + 1;
    }
    
    return occurrences;
}

function count_occurrences(text, search_term, case_sensitive = true) {
    return len(find_all_occurrences(text, search_term, case_sensitive));
}

function replace_all(text, search_term, replacement, case_sensitive = true) {
    if (!case_sensitive) {
        # Simple case-insensitive replacement
        let lower_text = text.lower();
        let lower_search = search_term.lower();
        let result = "";
        let i = 0;
        
        while (i < len(text)) {
            if (i + len(search_term) <= len(text) && 
                lower_text.slice(i, i + len(search_term)) == lower_search) {
                result += replacement;
                i += len(search_term);
            } else {
                result += text[i];
                i++;
            }
        }
        
        return result;
    } else {
        # Case-sensitive replacement
        return text.replace(search_term, replacement);
    }
}

# Text analysis functions
function get_word_frequency(text) {
    let words = text.lower().split(/\s+/);
    let frequency = {};
    
    for (let word in words) {
        word = word.trim();
        if (word != "") {
            # Remove punctuation from word
            word = remove_punctuation(word);
            
            if (frequency[word] == null) {
                frequency[word] = 0;
            }
            frequency[word]++;
        }
    }
    
    return frequency;
}

function get_most_common_words(text, limit = 10) {
    let frequency = get_word_frequency(text);
    
    # Convert to array and sort by frequency
    let sorted_words = [];
    for (let word in frequency) {
        sorted_words.push({"word": word, "count": frequency[word]});
    }
    
    sorted_words.sort((a, b) => b.count - a.count);
    
    return sorted_words.slice(0, limit);
}

function get_character_frequency(text) {
    let frequency = {};
    
    for (let i = 0; i < len(text); i++) {
        let char = text[i];
        if (frequency[char] == null) {
            frequency[char] = 0;
        }
        frequency[char]++;
    }
    
    return frequency;
}

# Text transformation functions
function reverse_text(text) {
    let result = "";
    for (let i = len(text) - 1; i >= 0; i--) {
        result += text[i];
    }
    return result;
}

function reverse_words(text) {
    let words = text.split(" ");
    let reversed = [];
    
    for (let i = len(words) - 1; i >= 0; i--) {
        reversed.push(words[i]);
    }
    
    return reversed.join(" ");
}

function pig_latin(text) {
    let words = text.split(" ");
    let result = [];
    
    for (let word in words) {
        if (len(word) == 0) {
            result.push(word);
            continue;
        }
        
        let first_char = word[0].lower();
        let rest = word.slice(1);
        
        if (len(word) == 1) {
            result.push(word + "ay");
        } else if ("aeiou".contains(first_char)) {
            result.push(word + "way");
        } else {
            result.push(rest + first_char + "ay");
        }
    }
    
    return result.join(" ");
}

