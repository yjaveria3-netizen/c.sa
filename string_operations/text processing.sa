# Advanced text processing
print("\n--- Advanced Text Processing ---");

# Text similarity (simple approach)
function text_similarity(text1, text2) {
    let words1 = get_word_frequency(text1);
    let words2 = get_word_frequency(text2);
    
    let all_words = {};
    for (let word in words1) {
        all_words[word] = true;
    }
    for (let word in words2) {
        all_words[word] = true;
    }
    
    let similarity = 0;
    let total_words = 0;
    
    for (let word in all_words) {
        let count1 = words1[word] || 0;
        let count2 = words2[word] || 0;
        
        similarity += min(count1, count2);
        total_words += max(count1, count2);
    }
    
    return total_words == 0 ? 1.0 : similarity / total_words;
}

# Text summarization (extractive)
function extract_summary(text, num_sentences = 3) {
    let sentences = [];
    let current = "";
    
    # Split into sentences
    for (let i = 0; i < len(text); i++) {
        current += text[i];
        if (".!?".contains(text[i])) {
            sentences.push(current.trim());
            current = "";
        }
    }
    
    if (current.trim() != "") {
        sentences.push(current.trim());
    }
    
    if (len(sentences) <= num_sentences) {
        return sentences.join(" ");
    }
    
    # Score sentences by word frequency
    let word_freq = get_word_frequency(text);
    let sentence_scores = [];
    
    for (let sentence in sentences) {
        let score = 0;
        let sentence_words = sentence.lower().split(/\s+/);
        
        for (let word in sentence_words) {
            word = remove_punctuation(word);
            if (word_freq[word] != null) {
                score += word_freq[word];
            }
        }
        
        sentence_scores.push({"sentence": sentence, "score": score});
    }
    
    # Sort by score and take top sentences
    sentence_scores.sort((a, b) => b.score - a.score);
    
    let summary_sentences = [];
    for (let i = 0; i < min(num_sentences, len(sentence_scores)); i++) {
        summary_sentences.push(sentence_scores[i].sentence);
    }
    
    return summary_sentences.join(" ");
}

