# text_encryption.sa - Text Encryption Examples
# C-style text encryption implementation in Quantum Language

print("=== Text Encryption Examples ===");

# Caesar Cipher
function caesar_cipher_encrypt(text, shift) {
    let result = "";
    
    for (let i = 0; i < len(text); i++) {
        let char = text[i];
        
        if (char >= 'a' && char <= 'z') {
            let shifted = (char.charCodeAt() - 97 + shift) % 26 + 97;
            result += chr(shifted);
        } else if (char >= 'A' && char <= 'Z') {
            let shifted = (char.charCodeAt() - 65 + shift) % 26 + 65;
            result += chr(shifted);
        } else {
            result += char;
        }
    }
    
    return result;
}

function caesar_cipher_decrypt(text, shift) {
    return caesar_cipher_encrypt(text, -shift);
}

# ROT13 (special case of Caesar cipher)
function rot13(text) {
    return caesar_cipher_encrypt(text, 13);
}

# Atbash Cipher
function atbash_cipher(text) {
    let result = "";
    
    for (let i = 0; i < len(text); i++) {
        let char = text[i];
        
        if (char >= 'a' && char <= 'z') {
            let reversed = 122 - (char.charCodeAt() - 97);
            result += chr(reversed);
        } else if (char >= 'A' && char <= 'Z') {
            let reversed = 90 - (char.charCodeAt() - 65);
            result += chr(reversed);
        } else {
            result += char;
        }
    }
    
    return result;
}

# Vigenère Cipher
function vigenere_encrypt(text, key) {
    let result = "";
    let key_index = 0;
    
    for (let i = 0; i < len(text); i++) {
        let char = text[i];
        
        if (char >= 'a' && char <= 'z') {
            let text_char = char.charCodeAt() - 97;
            let key_char = key[key_index % len(key)].charCodeAt() - 97;
            let encrypted = (text_char + key_char) % 26 + 97;
            result += chr(encrypted);
            key_index++;
        } else if (char >= 'A' && char <= 'Z') {
            let text_char = char.charCodeAt() - 65;
            let key_char = key[key_index % len(key)].upper().charCodeAt() - 65;
            let encrypted = (text_char + key_char) % 26 + 65;
            result += chr(encrypted);
            key_index++;
        } else {
            result += char;
        }
    }
    
    return result;
}

function vigenere_decrypt(text, key) {
    let result = "";
    let key_index = 0;
    
    for (let i = 0; i < len(text); i++) {
        let char = text[i];
        
        if (char >= 'a' && char <= 'z') {
            let text_char = char.charCodeAt() - 97;
            let key_char = key[key_index % len(key)].charCodeAt() - 97;
            let decrypted = (text_char - key_char + 26) % 26 + 97;
            result += chr(decrypted);
            key_index++;
        } else if (char >= 'A' && char <= 'Z') {
            let text_char = char.charCodeAt() - 65;
            let key_char = key[key_index % len(key)].upper().charCodeAt() - 65;
            let decrypted = (text_char - key_char + 26) % 26 + 65;
            result += chr(decrypted);
            key_index++;
        } else {
            result += char;
        }
    }
    
    return result;
}

# XOR Cipher
function xor_cipher(text, key) {
    let result = "";
    
    for (let i = 0; i < len(text); i++) {
        let text_char = text.charCodeAt(i);
        let key_char = key.charCodeAt(i % len(key));
        let encrypted = text_char ^ key_char;
        result += chr(encrypted);
    }
    
    return result;
}

# Simple substitution cipher
function substitution_encrypt(text, substitution_map) {
    let result = "";
    
    for (let i = 0; i < len(text); i++) {
        let char = text[i];
        let lower_char = char.lower();
        
        if (substitution_map[lower_char] != null) {
            let encrypted = substitution_map[lower_char];
            # Preserve case
            if (char >= 'A' && char <= 'Z') {
                result += encrypted.upper();
            } else {
                result += encrypted;
            }
        } else {
            result += char;
        }
    }
    
    return result;
}

function create_substitution_map() {
    let alphabet = "abcdefghijklmnopqrstuvwxyz";
    let shuffled = alphabet.split("");
    
    # Fisher-Yates shuffle
    for (let i = len(shuffled) - 1; i > 0; i--) {
        let j = randint(0, i);
        let temp = shuffled[i];
        shuffled[i] = shuffled[j];
        shuffled[j] = temp;
    }
    
    let substitution_map = {};
    for (let i = 0; i < len(alphabet); i++) {
        substitution_map[alphabet[i]] = shuffled[i];
    }
    
    return substitution_map;
}

