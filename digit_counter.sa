#include <stdio.h>

int main() {
    int num, digit, count = 0;
    printf("Enter a number: ");
    scanf("%d", &num);
    
    int original = num;
    while (num > 0) {
        digit = num % 10;
        count++;
        num /= 10;
    }
    
    printf("Number of digits in %d is %d\n", original, count);
    return 0;
}
