#include <stdio.h>

int main() {
    int num, digit, max = 0;
    printf("Enter a number: ");
    scanf("%d", &num);
    
    int original = num;
    while (num > 0) {
        digit = num % 10;
        if (digit > max) max = digit;
        num /= 10;
    }
    
    printf("Largest digit in %d is %d\n", original, max);
    return 0;
}
