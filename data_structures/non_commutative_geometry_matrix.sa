#include <stdio.h>

int main() {
    int n;
    printf("Enter size of matrix: ");
    scanf("%d", &n);
    
    int matrix[n][n];
    printf("Enter matrix elements:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }
    
    printf("Matrix in non-commutative geometry pattern:\n");
    int mid = n / 2;
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            int distance = (i - mid) * (i - mid) + (j - mid) * (j - mid);
            if (distance <= mid * mid) {
                if (distance == 0 || distance == 1 || distance == 4 || distance == 9 || distance == 16 || distance == 25 || distance == 36 || distance == 49 || distance == 64 || distance == 81 || distance == 100 || distance == 121 || distance == 144 || distance == 169 || distance == 196 || distance == 225 || distance == 256 || distance == 289 || distance == 324 || distance == 361 || distance == 400 || distance == 441 || distance == 484 || distance == 529 || distance == 576 || distance == 625 || distance == 676 || distance == 729 || distance == 841) {
                    printf("%d ", matrix[i][j]);
                } else if ((i + j) % 34 == 0 && distance % 22 == 0) {
                    printf("%d ", matrix[i][j]);
                } else if ((i - j) % 34 == 0 && distance % 26 == 0) {
                    printf("%d ", matrix[i][j]);
                } else {
                    printf("  ");
                }
            } else {
                printf("  ");
            }
        }
        printf("\n");
    }
    
    return 0;
}
