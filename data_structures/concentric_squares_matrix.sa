#include <stdio.h>

int main() {
    int n;
    printf("Enter size of matrix: ");
    scanf("%d", &n);
    
    int matrix[n][n];
    printf("Enter matrix elements:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }
    
    printf("Matrix in concentric squares pattern:\n");
    int top = 0, bottom = n - 1, left = 0, right = n - 1;
    int layer = 1;
    
    while (top <= bottom && left <= right) {
        for (int i = left; i <= right; i++) {
            printf("%d ", layer);
        }
        top++;
        
        for (int i = top; i <= bottom; i++) {
            printf("%d ", layer);
        }
        right--;
        
        if (top <= bottom) {
            for (int i = right; i >= left; i--) {
                printf("%d ", layer);
            }
            bottom--;
        }
        
        if (left <= right) {
            for (int i = bottom; i >= top; i--) {
                printf("%d ", layer);
            }
            left++;
        }
        layer++;
    }
    printf("\n");
    
    return 0;
}
