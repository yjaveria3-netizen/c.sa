# hash_table.sa - Hash Table Data Structure Implementation
# C-style hash table implementation in Quantum Language

# Hash Table Node class (for chaining)
class HashNode {
    constructor(key, value) {
        this.key = key;
        this.value = value;
        this.next = null;
    }
}

# Hash Table class
class HashTable {
    constructor(size) {
        this.size = size;
        this.table = [];
        this.count = 0;
        
        # Initialize table with empty lists
        for (let i = 0; i < size; i++) {
            this.table.push(null);
        }
    }
    
    # Hash function (simple string hash)
    hash(key) {
        if (typeof(key) == "number") {
            return key % this.size;
        }
        
        # String hashing
        let hash_value = 0;
        for (let i = 0; i < len(key); i++) {
            hash_value = (hash_value * 31 + key[i].charCodeAt()) % this.size;
        }
        return hash_value < 0 ? hash_value + this.size : hash_value;
    }
    
    # Insert or update a key-value pair
    insert(key, value) {
        let index = this.hash(key);
        let new_node = HashNode(key, value);
        
        if (this.table[index] == null) {
            this.table[index] = new_node;
        } else {
            # Check if key already exists and update
            let current = this.table[index];
            while (current != null) {
                if (current.key == key) {
                    current.value = value;
                    return true;
                }
                if (current.next == null) {
                    break;
                }
                current = current.next;
            }
            # Add to end of chain
            current.next = new_node;
        }
        
        this.count++;
        return true;
    }
    
    # Get value by key
    get(key) {
        let index = this.hash(key);
        let current = this.table[index];
        
        while (current != null) {
            if (current.key == key) {
                return current.value;
            }
            current = current.next;
        }
        
        return null;  # Key not found
    }
    
    # Remove a key-value pair
    remove(key) {
        let index = this.hash(key);
        let current = this.table[index];
        let prev = null;
        
        while (current != null) {
            if (current.key == key) {
                if (prev == null) {
                    this.table[index] = current.next;
                } else {
                    prev.next = current.next;
                }
                this.count--;
                return true;
            }
            prev = current;
            current = current.next;
        }
        
        return false;  # Key not found
    }
    
    # Check if key exists
    contains(key) {
        return this.get(key) != null;
    }
    
    # Get all keys
    keys() {
        let all_keys = [];
        
        for (let i = 0; i < this.size; i++) {
            let current = this.table[i];
            while (current != null) {
                all_keys.push(current.key);
                current = current.next;
            }
        }
        
        return all_keys;
    }
    
    # Get all values
    values() {
        let all_values = [];
        
        for (let i = 0; i < this.size; i++) {
            let current = this.table[i];
            while (current != null) {
                all_values.push(current.value);
                current = current.next;
            }
        }
        
        return all_values;
    }
    
    # Get current number of elements
    get_count() {
        return this.count;
    }
    
    # Check if hash table is empty
    is_empty() {
        return this.count == 0;
    }
    
    # Clear the hash table
    clear() {
        for (let i = 0; i < this.size; i++) {
            this.table[i] = null;
        }
        this.count = 0;
    }
    
    # Display hash table contents
    display() {
        if (this.is_empty()) {
            print("Hash table is empty");
            return;
        }
        
        print("Hash Table Contents:");
        for (let i = 0; i < this.size; i++) {
            if (this.table[i] != null) {
                print("Bucket", i, ":");
                let current = this.table[i];
                while (current != null) {
                    print("  ", current.key, ":", current.value);
                    current = current.next;
                }
            }
        }
    }
    
    # Get load factor
    get_load_factor() {
        return this.count / this.size;
    }
    
    # Display bucket distribution
    display_distribution() {
        print("Bucket Distribution:");
        let bucket_sizes = [];
        
        for (let i = 0; i < this.size; i++) {
            let size = 0;
            let current = this.table[i];
            while (current != null) {
                size++;
                current = current.next;
            }
            bucket_sizes.push(size);
        }
        
        for (let i = 0; i < this.size; i++) {
            if (bucket_sizes[i] > 0) {
                print("Bucket", i, ":", bucket_sizes[i], "elements");
            }
        }
        
        let max_bucket = max(bucket_sizes);
        let avg_bucket = this.count / this.size;
        print("Max bucket size:", max_bucket);
        print("Average bucket size:", avg_bucket.toFixed(2));
        print("Load factor:", this.get_load_factor().toFixed(2));
    }
}

# Test Hash Table
print("=== Hash Table Test ===");

let ht = HashTable(10);

# Test insert operations
print("\n--- Testing Insert Operations ---");
ht.insert("apple", 5);
ht.insert("banana", 3);
ht.insert("orange", 7);
ht.insert("grape", 2);
ht.insert("mango", 4);
ht.insert("apple", 8);  # Update existing key

print("After insertions:");
ht.display();

print("\nHash table properties:");
print("Count:", ht.get_count());
print("Load factor:", ht.get_load_factor().toFixed(2));

# Test get operations
print("\n--- Testing Get Operations ---");
print("Get 'apple':", ht.get("apple"));
print("Get 'banana':", ht.get("banana"));
