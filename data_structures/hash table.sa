# Test contains operation
print("\n--- Testing Contains Operation ---");
print("Contains 'orange':", ht.contains("orange"));
print("Contains 'pear':", ht.contains("pear"));

# Test remove operations
print("\n--- Testing Remove Operations ---");
print("Remove 'grape':", ht.remove("grape"));
print("Remove 'pear':", ht.remove("pear"));

print("\nAfter removals:");
ht.display();
print("Count:", ht.get_count());

# Test keys and values
print("\n--- Testing Keys and Values ---");
print("All keys:", ht.keys());
print("All values:", ht.values());

