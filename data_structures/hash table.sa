# Hash Table application: Symbol Table
print("\n=== Hash Table Application: Symbol Table ===");

class SymbolTable {
    constructor() {
        this.symbols = HashTable(100);
        this.scopes = [];
        this.current_scope = 0;
    }
    
    enter_scope(scope_name) {
        this.current_scope++;
        this.scopes.push({"name": scope_name, "symbols": []});
        print("Entered scope:", scope_name, "(Level:", this.current_scope, ")");
    }
    
    exit_scope() {
        if (len(this.scopes) > 0) {
            let scope = this.scopes.pop();
            # Remove symbols from this scope
            for (let symbol in scope.symbols) {
                this.symbols.remove(symbol);
            }
            this.current_scope--;
            print("Exited scope:", scope.name, "(Level:", this.current_scope, ")");
        }
    }
    
    declare(name, type, value) {
        if (this.symbols.contains(name)) {
            print("Error: Symbol", name, "already declared");
            return false;
        }
        
        let symbol_info = {
            "name": name,
            "type": type,
            "value": value,
            "scope": this.current_scope
        };
        
        this.symbols.insert(name, symbol_info);
        if (len(this.scopes) > 0) {
            this.scopes[len(this.scopes) - 1].symbols.push(name);
        }
        
        print("Declared", name, "as", type, "=", value);
        return true;
    }
    
    lookup(name) {
        let symbol = this.symbols.get(name);
        if (symbol != null) {
            print("Found", name, ":", symbol.type, "=", symbol.value, "(Scope:", symbol.scope, ")");
            return symbol;
        } else {
            print("Symbol", name, "not found");
            return null;
        }
    }
    
    update(name, new_value) {
        let symbol = this.symbols.get(name);
        if (symbol != null) {
            symbol.value = new_value;
            this.symbols.insert(name, symbol);  # Update
            print("Updated", name, "to", new_value);
            return true;
        } else {
            print("Cannot update undefined symbol", name);
            return false;
        }
    }
    
    display_symbols() {
        print("Current symbols in scope", this.current_scope, ":");
        let all_keys = this.symbols.keys();
        for (let key in all_keys) {
            let symbol = this.symbols.get(key);
            if (symbol.scope == this.current_scope) {
                print("  ", symbol.name, ":", symbol.type, "=", symbol.value);
            }
        }
    }
}

# Test symbol table
let sym_table = SymbolTable();
sym_table.enter_scope("main");
sym_table.declare("x", "int", 10);
sym_table.declare("y", "int", 20);
sym_table.declare("name", "string", "\"Hello\"");

sym_table.display_symbols();
sym_table.lookup("x");
sym_table.lookup("name");

sym_table.enter_scope("function");
sym_table.declare("x", "int", 30);  # Shadowing
sym_table.declare("result", "float", 3.14);

sym_table.display_symbols();
sym_table.lookup("x");

sym_table.exit_scope();
sym_table.lookup("x");

# Hash Table application: Cache
print("\n=== Hash Table Application: Cache ===");

class LRUCache {
    constructor(capacity) {
        this.capacity = capacity;
        this.cache = HashTable(capacity * 2);
        this.access_order = [];
    }
    
    get(key) {
        if (this.cache.contains(key)) {
            # Update access order
            let index = -1;
            for (let i = 0; i < len(this.access_order); i++) {
                if (this.access_order[i] == key) {
                    index = i;
                    break;
                }
            }
            
            if (index != -1) {
                this.access_order.splice(index, 1);
                this.access_order.push(key);
            }
            
            print("Cache HIT for key:", key);
            return this.cache.get(key);
        } else {
            print("Cache MISS for key:", key);
            return null;
        }
    }
    
    put(key, value) {
        if (this.cache.contains(key)) {
            # Update existing
            this.cache.insert(key, value);
            this._update_access_order(key);
            print("Updated cache for key:", key);
        } else {
            # Add new
            if (len(this.access_order) >= this.capacity) {
                # Remove least recently used
                let lru_key = this.access_order.shift();
                this.cache.remove(lru_key);
                print("Evicted LRU key:", lru_key);
            }
            
            this.cache.insert(key, value);
            this.access_order.push(key);
            print("Added to cache:", key, ":", value);
        }
    }
    
    _update_access_order(key) {
        let index = -1;
        for (let i = 0; i < len(this.access_order); i++) {
            if (this.access_order[i] == key) {
                index = i;
                break;
            }
        }
        
        if (index != -1) {
            this.access_order.splice(index, 1);
            this.access_order.push(key);
        }
    }
    
    display() {
        print("Cache Contents:");
        for (let i = 0; i < len(this.access_order); i++) {
            let key = this.access_order[i];
            let value = this.cache.get(key);
            print("  ", key, ":", value);
        }
    }
}

# Test LRU Cache
let cache = LRUCache(3);

cache.put("A", 1);
cache.put("B", 2);
cache.put("C", 3);
cache.display();

print("\nAccessing A:");
cache.get("A");

print("\nAdding D (should evict B):");
cache.put("D", 4);
cache.display();

print("\nAccessing B (should miss):");
cache.get("B");

print("\nAccessing C then adding E:");
cache.get("C");
cache.put("E", 5);
cache.display();

# Performance test
print("\n=== Performance Test ===");

function performance_test() {
    let ht = HashTable(1000);
    let num_operations = 10000;
    
    # Test insert performance
    let start_time = time();
    for (let i = 0; i < num_operations; i++) {
        let key = "key_" + i;
        let value = "value_" + i;
        ht.insert(key, value);
    }
    let insert_time = time() - start_time;
    
    # Test search performance
    start_time = time();
    for (let i = 0; i < num_operations; i++) {
        let key = "key_" + randint(0, num_operations - 1);
        ht.get(key);
    }
    let search_time = time() - start_time;
    
    # Test delete performance
    start_time = time();
    for (let i = 0; i < num_operations / 2; i++) {
        let key = "key_" + i;
        ht.remove(key);
    }
    let delete_time = time() - start_time;
    
    print("Hash Table Performance Test:");
    print("Inserted", num_operations, "elements in", insert_time, "seconds");
    print("Performed", num_operations, "searches in", search_time, "seconds");
    print("Deleted", num_operations / 2, "elements in", delete_time, "seconds");
    print("Final count:", ht.get_count());
    print("Load factor:", ht.get_load_factor().toFixed(2));
}

performance_test();
