#include <stdio.h>

int main() {
    int n;
    printf("Enter size of array: ");
    scanf("%d", &n);
    
    int arr[n];
    printf("Enter %d elements: ", n);
    for (int i = 0; i < n; i++) scanf("%d", &arr[i]);
    
    int sum = 0;
    for (int i = 0; i < n; i++) sum += arr[i];
    
    printf("Sum of array elements: %d\n", sum);
    printf("Average of array elements: %.2f\n", (float)sum / n);
    
    return 0;
}
