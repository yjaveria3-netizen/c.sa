print("Leaf count:", bt.get_leaf_count());

print("\nSearch operations:");
print("Search for 4:", bt.search(4));
print("Search for 8:", bt.search(8));

# Test Binary Search Tree
print("\n=== Binary Search Tree Test ===");

let bst = BinarySearchTree();
let values = [50, 30, 70, 20, 40, 60, 80, 10, 25, 35, 45];

for (let value in values) {
    bst.insert(value);
    print("Inserted:", value);
}

print("\nBST structure:");
bst.display();

print("\nBST traversals:");
print("In-order (sorted):", bst.inorder());
