print("Search for 55:", bst.search(55));
print("Search for 80:", bst.search(80));

print("\nBST delete operations:");
bst.delete(20);
print("Deleted 20 - In-order:", bst.inorder());

bst.delete(30);
print("Deleted 30 - In-order:", bst.inorder());

bst.delete(50);
print("Deleted 50 (root) - In-order:", bst.inorder());

print("\nFinal BST structure:");
bst.display();

# Tree applications
print("\n=== Tree Applications ===");

# Expression Tree Evaluation
class ExpressionTree {
    constructor() {
        this.root = null;
    }
    
    is_operator(c) {
        return c == '+' || c == '-' || c == '*' || c == '/' || c == '^';
    }
    
    construct_tree(postfix) {
        let stack = [];
        
        for (let token in postfix) {
            if (!this.is_operator(token)) {
                stack.push(TreeNode(token));
            } else {
                let right = stack.pop();
                let left = stack.pop();
                let node = TreeNode(token);
                node.left = left;
                node.right = right;
                stack.push(node);
            }
        }
        
        this.root = stack.pop();
    }
    
    evaluate(node) {
        if (node == null) {
            return 0;
        }
        
        if (!this.is_operator(node.data)) {
            return parseFloat(node.data);
        }
        
        let left_val = this.evaluate(node.left);
        let right_val = this.evaluate(node.right);
        
        if (node.data == '+') {
            return left_val + right_val;
        } else if (node.data == '-') {
            return left_val - right_val;
        } else if (node.data == '*') {
            return left_val * right_val;
        } else if (node.data == '/') {
            return left_val / right_val;
        } else if (node.data == '^') {
            return left_val ** right_val;
        }
        
        return 0;
    }
    
    infix_expression(node) {
        if (node == null) {
            return "";
        }
        
        if (!this.is_operator(node.data)) {
            return node.data;
        }
        
        let left_expr = this.infix_expression(node.left);
        let right_expr = this.infix_expression(node.right);
        
        return "(" + left_expr + " " + node.data + " " + right_expr + ")";
    }
    
    display() {
        print("Expression Tree:");
        this._display_helper(this.root, "", true);
    }
    
    _display_helper(node, prefix, is_last) {
        if (node == null) {
            return;
        }
        
        print(prefix + (is_last ? "└── " : "├── ") + str(node.data));
        
        if (node.left != null || node.right != null) {
            let new_prefix = prefix + (is_last ? "    " : "│   ");
            
            if (node.left != null) {
                this._display_helper(node.left, new_prefix, node.right == null);
            }
            
            if (node.right != null) {
                this._display_helper(node.right, new_prefix, true);
            }
        }
    }
}

# Test expression tree
let expr_tree = ExpressionTree();
let postfix_expr = ["3", "4", "+", "2", "*", "7", "/"];
expr_tree.construct_tree(postfix_expr);

print("Expression Tree:");
expr_tree.display();

print("Postfix:", postfix_expr.join(" "));
print("Infix:", expr_tree.infix_expression(expr_tree.root));
print("Result:", expr_tree.evaluate(expr_tree.root));

# Huffman Coding Tree
print("\n=== Huffman Coding ===");

class HuffmanNode extends TreeNode {
    constructor(data, freq) {
        super(data);
        this.frequency = freq;
    }
}

class HuffmanCoding {
    constructor() {
        this.root = null;
        this.codes = {};
    }
    
    build_codes(node, code) {
        if (node == null) {
            return;
        }
        
        if (node.data != null && node.data != "") {
            this.codes[node.data] = code;
            return;
        }
        
        this.build_codes(node.left, code + "0");
        this.build_codes(node.right, code + "1");
    }
    
    encode(text) {
        # Count frequencies
        let freq_map = {};
        for (let char in text) {
            if (freq_map[char] == null) {
                freq_map[char] = 0;
            }
            freq_map[char]++;
        }
        
        # Create priority queue (simple array for demonstration)
        let nodes = [];
        for (let char in freq_map) {
            nodes.push(HuffmanNode(char, freq_map[char]));
        }
        
        # Build Huffman tree
        while (len(nodes) > 1) {
            # Sort by frequency
            nodes.sort((a, b) => a.frequency - b.frequency);
            
            let left = nodes.shift();
            let right = nodes.shift();
            
            let parent = HuffmanNode("", left.frequency + right.frequency);
            parent.left = left;
            parent.right = right;
            
            nodes.push(parent);
        }
        
        this.root = nodes[0];
        this.build_codes(this.root, "");
        
        # Encode text
        let encoded = "";
        for (let char in text) {
            encoded += this.codes[char];
        }
        
        return encoded;
    }
    
    get_codes() {
        return this.codes;
    }
}

# Test Huffman coding
let huffman = HuffmanCoding();
let text = "hello world";
let encoded = huffman.encode(text);

print("Original text:", text);
print("Huffman codes:", huffman.get_codes());
print("Encoded:", encoded);

# Performance test
print("\n=== Performance Test ===");

function performance_test() {
    let bst = BinarySearchTree();
    let num_elements = 1000;
    
    # Test insertion performance
    let start_time = time();
    for (let i = 0; i < num_elements; i++) {
        bst.insert(randint(1, 10000));
    }
    let insert_time = time() - start_time;
    
    # Test search performance
    start_time = time();
    for (let i = 0; i < 100; i++) {
        bst.search(randint(1, 10000));
    }
    let search_time = time() - start_time;
    
    print("BST Performance Test:");
    print("Inserted", num_elements, "elements in", insert_time, "seconds");
    print("Performed 100 searches in", search_time, "seconds");
    print("Tree height:", bst.get_height());
    print("Tree size:", bst.get_size());
}

performance_test();
