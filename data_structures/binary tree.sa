# binary_tree.sa - Binary Tree Data Structure Implementation
# C-style binary tree implementation in Quantum Language

# Binary Tree Node class
class TreeNode {
    constructor(data) {
        this.data = data;
        this.left = null;
        this.right = null;
    }
    
    set_left(node) {
        this.left = node;
    }
    
    set_right(node) {
        this.right = node;
    }
    
    is_leaf() {
        return this.left == null && this.right == null;
    }
}

# Binary Tree class
class BinaryTree {
    constructor(root_data) {
        this.root = root_data != null ? TreeNode(root_data) : null;
    }
    
    # Insert a node in the binary tree (level-order insertion)
    insert(data) {
        let new_node = TreeNode(data);
        
        if (this.root == null) {
            this.root = new_node;
            return true;
        }
        
        let queue = [];
        queue.push(this.root);
        
        while (len(queue) > 0) {
            let current = queue.shift();
            
            if (current.left == null) {
                current.left = new_node;
                return true;
            } else {
                queue.push(current.left);
            }
            
            if (current.right == null) {
                current.right = new_node;
                return true;
            } else {
                queue.push(current.right);
            }
        }
        
        return false;
    }
    
    # In-order traversal (Left, Root, Right)
    inorder_traversal(node, result) {
        if (node == null) {
            return;
        }
        
        this.inorder_traversal(node.left, result);
        result.push(node.data);
        this.inorder_traversal(node.right, result);
    }
    
    inorder() {
        let result = [];
        this.inorder_traversal(this.root, result);
        return result;
    }
    
    # Pre-order traversal (Root, Left, Right)
    preorder_traversal(node, result) {
        if (node == null) {
            return;
        }
        
        result.push(node.data);
        this.preorder_traversal(node.left, result);
        this.preorder_traversal(node.right, result);
    }
    
    preorder() {
        let result = [];
        this.preorder_traversal(this.root, result);
        return result;
    }
    
    # Post-order traversal (Left, Right, Root)
    postorder_traversal(node, result) {
        if (node == null) {
            return;
        }
        
        this.postorder_traversal(node.left, result);
        this.postorder_traversal(node.right, result);
        result.push(node.data);
    }
    
    postorder() {
        let result = [];
        this.postorder_traversal(this.root, result);
        return result;
    }
    
    # Level-order traversal (Breadth-First)
    levelorder() {
        if (this.root == null) {
            return [];
        }
        
        let result = [];
        let queue = [];
        queue.push(this.root);
        
        while (len(queue) > 0) {
            let current = queue.shift();
            result.push(current.data);
            
            if (current.left != null) {
                queue.push(current.left);
            }
            
            if (current.right != null) {
                queue.push(current.right);
            }
        }
        
        return result;
    }
    
    # Search for a value in the tree
    search(data) {
        if (this.root == null) {
            return false;
        }
        
        let queue = [];
        queue.push(this.root);
        
        while (len(queue) > 0) {
            let current = queue.shift();
            
            if (current.data == data) {
                return true;
            }
            
            if (current.left != null) {
                queue.push(current.left);
            }
            
            if (current.right != null) {
                queue.push(current.right);
            }
        }
        
        return false;
    }
    
    # Get the height of the tree
    height(node) {
        if (node == null) {
            return 0;
        }
        
        let left_height = this.height(node.left);
        let right_height = this.height(node.right);
        
        return max(left_height, right_height) + 1;
    }
    
    get_height() {
        return this.height(this.root);
    }
    
    # Count the number of nodes
    count_nodes(node) {
        if (node == null) {
            return 0;
        }
        
        return 1 + this.count_nodes(node.left) + this.count_nodes(node.right);
    }
    
    get_size() {
        return this.count_nodes(this.root);
    }
    
    # Count leaf nodes
    count_leaves(node) {
        if (node == null) {
            return 0;
        }
        
        if (node.is_leaf()) {
            return 1;
        }
        
        return this.count_leaves(node.left) + this.count_leaves(node.right);
    }
    
    get_leaf_count() {
        return this.count_leaves(this.root);
    }
    
    # Display tree structure (visual representation)
    display() {
        if (this.root == null) {
            print("Tree is empty");
            return;
        }
        
        print("Binary Tree Structure:");
        this._display_helper(this.root, "", true);
    }
    
    _display_helper(node, prefix, is_last) {
        if (node == null) {
            return;
        }
        
        print(prefix + (is_last ? "└── " : "├── ") + str(node.data));
        
        if (node.left != null || node.right != null) {
            let new_prefix = prefix + (is_last ? "    " : "│   ");
            
            if (node.left != null) {
                this._display_helper(node.left, new_prefix, node.right == null);
            }
            
            if (node.right != null) {
                this._display_helper(node.right, new_prefix, true);
            }
        }
    }
}

# Binary Search Tree class (extends BinaryTree)
class BinarySearchTree extends BinaryTree {
    constructor() {
        super(null);
    }
    
    # Insert a node in BST
    insert(data) {
        this.root = this._insert_recursive(this.root, data);
    }
    
    _insert_recursive(node, data) {
        if (node == null) {
            return TreeNode(data);
        }
        
        if (data < node.data) {
            node.left = this._insert_recursive(node.left, data);
        } else if (data > node.data) {
            node.right = this._insert_recursive(node.right, data);
        }
        
        return node;
    }
    
    # Search in BST
    search(data) {
        return this._search_recursive(this.root, data);
    }
    
    _search_recursive(node, data) {
        if (node == null) {
            return false;
        }
        
        if (data == node.data) {
            return true;
        } else if (data < node.data) {
            return this._search_recursive(node.left, data);
        } else {
            return this._search_recursive(node.right, data);
        }
    }
    
    # Find minimum value node
    find_min(node) {
        while (node.left != null) {
            node = node.left;
        }
        return node;
    }
    
    # Delete a node from BST
    delete(data) {
        this.root = this._delete_recursive(this.root, data);
    }
    
    _delete_recursive(node, data) {
        if (node == null) {
            return null;
        }
        
        if (data < node.data) {
            node.left = this._delete_recursive(node.left, data);
        } else if (data > node.data) {
            node.right = this._delete_recursive(node.right, data);
        } else {
            # Node with only one child or no child
            if (node.left == null) {
                return node.right;
            } else if (node.right == null) {
                return node.left;
            }
            
            # Node with two children
            let temp = this.find_min(node.right);
            node.data = temp.data;
            node.right = this._delete_recursive(node.right, temp.data);
        }
        
        return node;
    }
}

# Test Binary Tree
print("=== Binary Tree Test ===");

let bt = BinaryTree(1);
bt.insert(2);
bt.insert(3);
bt.insert(4);
bt.insert(5);
bt.insert(6);
