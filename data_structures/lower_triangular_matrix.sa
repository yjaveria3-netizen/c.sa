#include <stdio.h>

int main() {
    int n;
    printf("Enter size of matrix: ");
    scanf("%d", &n);
    
    int matrix[n][n];
    printf("Enter matrix elements:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }
    
    int isLowerTriangular = 1;
    for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; j++) {
            if (matrix[i][j] != 0) {
                isLowerTriangular = 0;
                break;
            }
        }
    }
    
    if (isLowerTriangular) {
        printf("Matrix is lower triangular\n");
    } else {
        printf("Matrix is not lower triangular\n");
    }
    
    return 0;
}
