# queue.sa - Queue Data Structure Implementation
# C-style queue implementation in Quantum Language

# Queue class implementation
class Queue {
    constructor() {
        this.items = [];
        this.front = 0;
        this.rear = -1;
        this.size = 0;
    }
    
    # Enqueue an element to the rear of the queue
    enqueue(item) {
        this.items.push(item);
        this.rear++;
        this.size++;
    }
    
    # Dequeue an element from the front of the queue
    dequeue() {
        if (this.isEmpty()) {
            print("Error: Queue underflow - cannot dequeue from empty queue");
            return null;
        }
        
        let item = this.items[this.front];
        this.front++;
        this.size--;
        
        # Reset pointers when queue becomes empty
        if (this.isEmpty()) {
            this.front = 0;
            this.rear = -1;
        }
        
        return item;
    }
    
    # Peek at the front element without removing it
    peek() {
        if (this.isEmpty()) {
            print("Error: Queue is empty - cannot peek");
            return null;
        }
        return this.items[this.front];
    }
    
    # Check if the queue is empty
    isEmpty() {
        return this.size == 0;
    }
    
    # Get the current size of the queue
    getSize() {
        return this.size;
    }
    
    # Clear the queue
    clear() {
        this.items = [];
        this.front = 0;
        this.rear = -1;
        this.size = 0;
    }
    
    # Display the queue contents
    display() {
        if (this.isEmpty()) {
            print("Queue is empty");
            return;
        }
        
        print("Queue (front to rear):");
        for (let i = this.front; i <= this.rear; i++) {
            print("  ", this.items[i]);
        }
    }
    
    # Convert queue to array
    toArray() {
        let result = [];
        for (let i = this.front; i <= this.rear; i++) {
            result.push(this.items[i]);
        }
        return result;
    }
}

# Test the Queue implementation
print("=== Queue Implementation Test ===");

let queue = Queue();
print("Created new queue");
